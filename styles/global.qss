/* ============================================================
   NOVA BROWSER  —  "Obsidian Glass" Dark Theme
   Arc x Safari fusion: spatial depth, warm-tinted glass,
   razor-thin borders, indigo-violet accent (#7B6FF0)
   ============================================================ */

/* ── Reset / Base ────────────────────────────────────────── */
* {
    font-family: "SF Pro Display", "Segoe UI Variable", "Helvetica Neue", sans-serif;
    font-size: 13px;
    color: #D4D4DC;
    border: none;
    outline: none;
    margin: 0;
    padding: 0;
}

QMainWindow,
QWidget {
    background-color: #0D0D10;
}

/* ── TopBar ──────────────────────────────────────────────── */
TopBar {
    background-color: #111116;
    border-bottom: 1px solid #1C1C24;
    min-height: 46px;
    max-height: 46px;
    padding: 0 10px;
}

/* ── URL / Search Bar ────────────────────────────────────── */
QLineEdit {
    background-color: #18181F;
    color: #D4D4DC;
    border: 1px solid #252530;
    border-radius: 22px;
    padding: 6px 18px;
    font-size: 13px;
    selection-background-color: #7B6FF0;
    selection-color: #FFFFFF;
}

QLineEdit:focus {
    background-color: #1C1C26;
    border: 1px solid #7B6FF0;
}

QLineEdit:hover:!focus {
    border: 1px solid #2E2E3E;
}

/* ── Buttons (general) ───────────────────────────────────── */
QPushButton {
    background-color: transparent;
    color: #686878;
    border-radius: 8px;
    padding: 5px 9px;
    font-size: 15px;
    font-weight: 400;
}

QPushButton:hover {
    background-color: #1A1A22;
    color: #B8B8C8;
}

QPushButton:pressed {
    background-color: #222230;
    color: #D4D4DC;
}

QPushButton:disabled {
    color: #2E2E3C;
}

/* ── Window Controls ─────────────────────────────────────── */
QPushButton#close_btn {
    color: #484858;
    border-radius: 7px;
    font-size: 12px;
    min-width: 26px;
    max-width: 26px;
    min-height: 26px;
    max-height: 26px;
}

QPushButton#close_btn:hover {
    background-color: #5C1F1F;
    color: #FF6B6B;
}

QPushButton#min_btn,
QPushButton#max_btn {
    color: #484858;
    border-radius: 7px;
    font-size: 12px;
    min-width: 26px;
    max-width: 26px;
    min-height: 26px;
    max-height: 26px;
}

QPushButton#min_btn:hover,
QPushButton#max_btn:hover {
    background-color: #1A1A22;
    color: #B8B8C8;
}

/* ── Sidebar Container ───────────────────────────────────── */
Sidebar {
    background-color: #0D0D10;
}

/* ── Sidebar Icon Rail ───────────────────────────────────── */
#sidebar_icon_bar {
    background-color: #0F0F13;
    border-right: 1px solid #1A1A22;
    padding: 8px 5px;
    min-width: 46px;
    max-width: 46px;
}

#sidebar_icon_bar QPushButton {
    background-color: transparent;
    border-radius: 10px;
    padding: 7px;
    margin: 2px 0;
    min-width: 36px;
    max-width: 36px;
    min-height: 36px;
    max-height: 36px;
    color: #545464;
    font-size: 16px;
}

#sidebar_icon_bar QPushButton:hover {
    background-color: #18181F;
    color: #9898A8;
}

#sidebar_icon_bar QPushButton[active="true"] {
    background-color: #1C1C2A;
    color: #7B6FF0;
    border-left: 2px solid #7B6FF0;
    border-radius: 0 8px 8px 0;
    padding-left: 5px;
}

/* ── Sidebar Stack (panel area) ──────────────────────────── */
#sidebar_stack {
    background-color: #0F0F14;
    border-right: 1px solid #1A1A22;
}

/* ── Section / Panel Labels ──────────────────────────────── */
QLabel#section_label {
    color: #3E3E52;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.8px;
    padding: 14px 14px 6px 14px;
    background-color: transparent;
}

QLabel {
    color: #686878;
    font-size: 13px;
    background-color: transparent;
}

/* ── Scroll Areas ────────────────────────────────────────── */
QScrollArea {
    background-color: transparent;
    border: none;
}

QScrollArea > QWidget > QWidget {
    background-color: transparent;
}

QScrollBar:vertical {
    background: transparent;
    width: 4px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: #252530;
    border-radius: 2px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #7B6FF0;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
    height: 0;
}

QScrollBar:horizontal {
    height: 4px;
    background: transparent;
}

QScrollBar::handle:horizontal {
    background: #252530;
    border-radius: 2px;
}

/* ── Bookmark Items ──────────────────────────────────────── */
#bookmark_item {
    background-color: #13131A;
    border: 1px solid #1E1E28;
    border-radius: 10px;
    margin: 2px 8px;
}

#bookmark_btn {
    background-color: transparent;
    color: #A0A0B4;
    text-align: left;
    padding: 7px 10px;
    font-size: 12px;
    border-radius: 9px;
}

#bookmark_btn:hover {
    color: #C8C8DC;
    background-color: transparent;
}

#delete_btn {
    background-color: transparent;
    color: #303040;
    border-radius: 5px;
    font-size: 10px;
    font-weight: 600;
    min-width: 20px;
    max-width: 20px;
    min-height: 20px;
    max-height: 20px;
    padding: 0;
    margin-right: 6px;
}

#delete_btn:hover {
    background-color: #2A1010;
    color: #E05555;
}

/* ── Tabs (browser tab bar) ──────────────────────────────── */
QTabWidget::pane {
    border: none;
    background-color: #0D0D10;
}

QTabBar {
    background-color: #0D0D10;
}

QTabBar::tab {
    background-color: #111116;
    color: #484858;
    padding: 7px 16px;
    border-right: 1px solid #1A1A22;
    border-bottom: 2px solid transparent;
    min-width: 90px;
    max-width: 180px;
    font-size: 12px;
}

QTabBar::tab:selected {
    background-color: #0D0D10;
    color: #D4D4DC;
    border-bottom: 2px solid #7B6FF0;
}

QTabBar::tab:hover:!selected {
    background-color: #151519;
    color: #8888A0;
}

QTabBar::close-button {
    subcontrol-position: right;
    padding: 2px;
}

QTabBar::close-button:hover {
    background-color: #2A1A1A;
    border-radius: 3px;
}

/* ── Resize Handle ───────────────────────────────────────── */
ResizeHandle {
    background-color: #111116;
    min-width: 4px;
    max-width: 4px;
}

ResizeHandle:hover {
    background-color: #7B6FF0;
}

ResizeHandle QLabel {
    color: transparent;
}

/* ── Dialogs ─────────────────────────────────────────────── */
QDialog {
    background-color: #111116;
    border: 1px solid #1E1E2A;
    border-radius: 12px;
}

QDialog QLabel {
    color: #686878;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    padding-bottom: 3px;
    background-color: transparent;
}

QDialog QLineEdit {
    margin-bottom: 10px;
}

QDialog QPushButton {
    background-color: #7B6FF0;
    color: #FFFFFF;
    border-radius: 8px;
    padding: 7px 16px;
    font-size: 13px;
    font-weight: 500;
    min-width: 70px;
}

QDialog QPushButton:hover {
    background-color: #8B7FFF;
    color: #FFFFFF;
}

QDialog QPushButton:pressed {
    background-color: #6B5FE0;
}

/* ── Sidebar Web Panel — Mini Nav Bar ────────────────────── */
#sidebar_nav_bar {
    background-color: #111116;
    border-bottom: 1px solid #1C1C24;
    min-height: 38px;
    max-height: 38px;
}

#sidebar_nav_btn {
    background-color: transparent;
    color: #686878;
    border-radius: 7px;
    font-size: 14px;
    padding: 0;
}

#sidebar_nav_btn:hover {
    background-color: #1A1A22;
    color: #B8B8C8;
}

#sidebar_nav_btn:pressed {
    background-color: #222230;
    color: #D4D4DC;
}

#sidebar_nav_btn:disabled {
    color: #2E2E3C;
}

#sidebar_url_bar {
    background-color: #18181F;
    color: #888898;
    border: 1px solid #1E1E28;
    border-radius: 14px;
    padding: 3px 12px;
    font-size: 11px;
    selection-background-color: #7B6FF0;
}

#sidebar_url_bar:focus {
    border: 1px solid #2A2A3A;
    color: #A8A8B8;
}

/* ── Full-tab History Page ───────────────────────────────── */
#history_full_page {
    background-color: #0D0D10;
}

#history_page_header {
    background-color: #0D0D10;
    border-bottom: 1px solid #1A1A22;
}

#history_page_title {
    font-size: 22px;
    font-weight: 600;
    color: #C8C8DC;
    background-color: transparent;
    letter-spacing: -0.3px;
}

#history_page_clear_btn {
    background-color: transparent;
    color: #3A3A52;
    font-size: 12px;
    border: 1px solid #1E1E2A;
    border-radius: 8px;
    padding: 5px 14px;
}

#history_page_clear_btn:hover {
    background-color: #2A1010;
    border-color: #4A2020;
    color: #E05555;
}

#history_page_scroll {
    background-color: #0D0D10;
    border: none;
}

#history_page_list {
    background-color: #0D0D10;
}

#history_page_day_divider {
    color: #2E2E42;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.4px;
    padding: 20px 0 8px 0;
    background-color: transparent;
}

#history_page_row {
    background-color: transparent;
    border-bottom: 1px solid #13131A;
}

#history_page_row:hover {
    background-color: #111116;
}

#history_page_favicon {
    background-color: transparent;
    border-radius: 6px;
    padding: 0;
}

#history_page_favicon:hover {
    background-color: #1A1A22;
}

#history_page_text_col {
    background-color: transparent;
}

#history_page_title_btn {
    background-color: transparent;
    color: #B8B8CC;
    text-align: left;
    font-size: 13px;
    padding: 0 2px;
    border-radius: 4px;
}

#history_page_title_btn:hover {
    color: #7B6FF0;
    background-color: transparent;
}

#history_page_url_label {
    color: #38384E;
    font-size: 11px;
    padding: 0 2px;
    background-color: transparent;
}

#history_page_time_label {
    color: #2E2E42;
    font-size: 11px;
    background-color: transparent;
}

#history_page_empty {
    color: #2A2A3E;
    font-size: 14px;
    padding: 60px;
    background-color: transparent;
    background-color: transparent;
}

/* ── Home Page ───────────────────────────────────────────── */
#home_page {
    background-color: #0D0D10;
}

#home_scroll {
    background-color: #0D0D10;
    border: none;
}

#home_container {
    background-color: #0D0D10;
}

#home_greeting {
    font-size: 38px;
    font-weight: 300;
    color: #C8C8DC;
    letter-spacing: -0.5px;
    background-color: transparent;
}

#home_date {
    font-size: 14px;
    color: #38384E;
    background-color: transparent;
    letter-spacing: 0.3px;
}

#home_clock {
    font-size: 52px;
    font-weight: 200;
    color: #3A3A52;
    letter-spacing: -1px;
    background-color: transparent;
}

#home_section_label {
    color: #2E2E42;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    background-color: transparent;
    padding: 0;
}

/* ── Bookmark Tiles ──────────────────────────────────────── */
#home_bm_grid {
    background-color: transparent;
}

#bm_tile {
    background-color: #111116;
    border: 1px solid #1A1A22;
    border-radius: 14px;
}

#bm_tile:hover {
    background-color: #15151C;
    border-color: #2A2A3A;
}

#bm_tile_icon {
    background-color: #1A1A24;
    border-radius: 12px;
    padding: 0;
}

#bm_tile_icon:hover {
    background-color: #22223A;
}

#bm_tile_label {
    color: #686878;
    font-size: 11px;
    background-color: transparent;
}

#home_empty_label {
    color: #2A2A3E;
    font-size: 13px;
    background-color: transparent;
    padding: 8px 0;
}

/* ── Weather Card ────────────────────────────────────────── */
#weather_card {
    background-color: #111116;
    border: 1px solid #1A1A22;
    border-radius: 18px;
}

#weather_city {
    font-size: 14px;
    font-weight: 500;
    color: #686878;
    letter-spacing: 0.5px;
    background-color: transparent;
}

#weather_icon {
    font-size: 32px;
    background-color: transparent;
}

#weather_temp {
    font-size: 56px;
    font-weight: 200;
    color: #C8C8DC;
    letter-spacing: -2px;
    background-color: transparent;
    padding: 2px 0 0 0;
}

#weather_desc {
    font-size: 13px;
    color: #38384E;
    background-color: transparent;
    padding-bottom: 2px;
}

#weather_divider {
    background-color: #1A1A22;
    color: #1A1A22;
    max-height: 1px;
}

#weather_stat_value {
    font-size: 13px;
    font-weight: 500;
    color: #8888A0;
    background-color: transparent;
}

#weather_stat_label {
    font-size: 9px;
    font-weight: 600;
    color: #2E2E42;
    letter-spacing: 1px;
    background-color: transparent;
}

/* ── Tooltips ────────────────────────────────────────────── */
QToolTip {
    background-color: #1A1A22;
    color: #C0C0D0;
    border: 1px solid #2A2A36;
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 12px;
}
